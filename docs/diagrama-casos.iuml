@startuml
left to right direction

class Usuario{
    id
    nome 
    email
    senha
    tipoUsuario 
    ativo 
    autenticar()
    ehGerente()
}

class Cliente{
    id
    nome
    telefone
    preferencias
    dataCadastro 
}

class GestaoService{
    cadastrarUsuario()
    removerUsuario()
    listarUsuarios()
    cadastrarCliente()
    buscarCliente()
    obterHistoricoCliente()
}

class AgendamentoService{
    criarAgendamento()
    reagendar()
    cancelarAgendamento()
    verificarDisponibilidade()
    obterAgenda()
    finalizarAtendimento()
    gerarRelatorio()   
}

class Agendamento{
    id
    clientId
    profissionalId
    dataHora
    tipoServico
    status
    valor
    tipoPagamento
    horaInicio
    observacoes
    reagendar()
    cancelar()
    finalizar()
    conflita()
}

GestaoService ..> Usuario : gerencia
GestaoService ..> Cliente : gerencia

AgendamentoService ..> Usuario : consulta
AgendamentoService ..> Cliente : consulta
AgendamentoService ..> Agendamento : gerencia

Usuario "1" *-- "0..*" Agendamento : atende
Cliente "1" *-- "0..*" Agendamento : possui

@enduml